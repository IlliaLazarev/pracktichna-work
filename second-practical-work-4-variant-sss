<?php
$transactions = [
    ["amount" => 1200, "type" => "in",  "date" => "2026-04-01"],
    ["amount" => 350,  "type" => "out", "date" => "2026-04-02"],
    ["amount" => 700,  "type" => "out", "date" => "2026-04-03"],
    ["amount" => 2000, "type" => "in",  "date" => "2026-04-04"],
    ["amount" => 150,  "type" => "out", "date" => "2026-04-05"],
    ["amount" => 500,  "type" => "out", "date" => "2026-04-06"],
    ["amount" => 800,  "type" => "in",  "date" => "2026-04-07"],
    ["amount" => 250,  "type" => "out", "date" => "2026-04-08"]
];

function calculateTotal($transactions, $filter) {
    $filteredTransactions = array_filter($transactions, $filter);

    $total = 0;

    foreach ($filteredTransactions as $transaction) {
        $total += $transaction["amount"];
    }

    return [
        "filtered" => $filteredTransactions,
        "total" => $total
    ];
}

function isOutgoing($transaction) {
    return $transaction["type"] === "out";
}

$result = calculateTotal($transactions, "isOutgoing");

$outgoingTransactions = $result["filtered"];
$totalOutgoing = $result["total"];
?>

